# review-automata 環境変数テンプレート
# このファイルを .env にコピーして値を設定してください。
# .env はコミット禁止（.gitignore に登録済み）

# ---- IMAP 設定 ----
# Gmail の IMAP アドレス（デフォルト: imap.gmail.com:993）
MAIL_IMAP_ADDR=imap.gmail.com:993

# Gmail アドレス（例: yourname@gmail.com）
MAIL_USERNAME=yourname@gmail.com

# Gmail App Password（16 文字・スペースなし）
# 取得方法: Google アカウント → セキュリティ → 2段階認証 → アプリパスワード
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 監視するメールボックス（デフォルト: INBOX）
MAIL_MAILBOX=INBOX
